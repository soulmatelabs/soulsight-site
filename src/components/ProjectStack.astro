---
import { getCollection } from 'astro:content';

const featureEntries = await getCollection('features');
const features = featureEntries.map(entry => entry.data);
---

<section id="stack" class="py-16 md:py-32 bg-white relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="mb-20 space-y-4">
      <h2 class="font-heading text-5xl md:text-6xl text-[var(--color-secondary)]">The Sovereign Stack</h2>
      <p class="font-body text-xl text-gray-500 max-w-2xl uppercase tracking-widest text-sm">Hardware-level privacy meets advanced intelligence.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {features.map((f) => (
        <div class="group space-y-6 p-8 rounded-2xl border border-gray-100 hover:border-[var(--color-highlight)] transition-all duration-500 hover:shadow-2xl hover:shadow-sky-100 bg-white">
          <div class="w-16 h-16 bg-sky-50 rounded-xl flex items-center justify-center text-[var(--color-highlight)] group-hover:bg-[var(--color-highlight)] group-hover:text-white transition-colors duration-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={f.icon} />
            </svg>
          </div>
          <div class="space-y-2">
            <span class="text-xs uppercase tracking-[0.3em] text-[var(--color-accent)] font-bold">{f.tech}</span>
            <h3 class="font-heading text-3xl text-[var(--color-secondary)]">{f.title}</h3>
            <p class="font-body text-gray-600 leading-relaxed">
              {f.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
  
  <!-- Subtle Background Decor -->
  <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-96 h-96 bg-sky-50 rounded-full blur-3xl opacity-50 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/4 w-96 h-96 bg-blue-50 rounded-full blur-3xl opacity-50 pointer-events-none"></div>
</section>
